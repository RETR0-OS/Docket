{
  "manifest_version": 3,
  "name": "Docket",
  "key": "",
  "version": "1.0.0",
  "description": "Type :commands: in any text field to interact with your Google Calendar.",
  "permissions": ["identity", "storage"],
  "host_permissions": ["<all_urls>"],
  "oauth2": {
    "client_id": "359886766041-0kq7887sr9ap2o7kia2u9m069r8elhg0.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/calendar"
    ]
  },
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
